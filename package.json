{
  "name": "doctor.com",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.4.18",
      "@types/express": "^5.0.1",
      "@types/pg": "^8.16.0",
      "@trpc/tanstack-react-query": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-form": "^1.28.0",
      "@better-auth/expo": "^1.4.18",
      "drizzle-kit": "^0.31.8",
      "drizzle-orm": "^0.45.1",
      "express": "^5.1.0",
      "pg": "^8.17.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types --filter=server --filter=@doctor.com/api --filter=@doctor.com/db --filter=@doctor.com/auth --filter=@doctor.com/shared",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @doctor.com/db db:push",
    "db:studio": "turbo -F @doctor.com/db db:studio",
    "db:generate": "turbo -F @doctor.com/db db:generate",
    "db:migrate": "turbo -F @doctor.com/db db:migrate",
    "db:start": "turbo -F @doctor.com/db db:start",
    "db:watch": "turbo -F @doctor.com/db db:watch",
    "db:stop": "turbo -F @doctor.com/db db:stop",
    "db:down": "turbo -F @doctor.com/db db:down"
  },
  "dependencies": {
    "@doctor.com/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@doctor.com/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.20"
}
