{
  "name": "server",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./shared/schemas": {
      "default": "./src/shared/schemas/index.ts"
    },
    "./shared/types": {
      "default": "./src/shared/types/index.ts"
    },
    "./shared/errors": {
      "default": "./src/shared/errors/index.ts"
    },
    "./infrastructure/db/schema": {
      "default": "./src/infrastructure/db/schema.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "check-types": "tsc -b",
    "db:generate": "drizzle-kit generate --config ./src/infrastructure/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./src/infrastructure/db/drizzle.config.ts",
    "dev": "bun src/index.ts",
    "dev:watch": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@doctor.com/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/express": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
